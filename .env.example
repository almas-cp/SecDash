# SecDash environment example
# Copy values into your shell environment or your own local .env file.

# Required for Groq-backed CVE status classification.
GROQ_API_KEY=your_groq_api_key_here

# Optional Groq settings.
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_TIMEOUT_SECONDS=30

# Delay between CVE pipeline items. Each item includes CVE API lookup plus optional Groq classification.
CVE_REQUEST_DELAY_SECONDS=5

# Optional app secret. Change this for any non-local use.
SECDASH_SECRET_KEY=change_me_to_a_long_random_value
